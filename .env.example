# -----------------------------------------------------------------------------
# Required — the app will not boot without these
# -----------------------------------------------------------------------------

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# GitHub — https://github.com/settings/tokens (classic PAT with `repo` scope)
# Users can override this per-account in the UI; this is the default fallback.
GITHUB_TOKEN=ghp_...

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_dev_toolkit_development

# Redis (Sidekiq)
REDIS_URL=redis://localhost:6379/0

# Rails secrets — generate with `bin/rails secret`
SECRET_KEY_BASE=replace_me_with_rails_secret_output
RAILS_MASTER_KEY=replace_me_with_contents_of_config_master_key

# -----------------------------------------------------------------------------
# Model selection — override to upgrade the whole app in one place
# -----------------------------------------------------------------------------

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_REASONING_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMS=1536

# -----------------------------------------------------------------------------
# Optional — sensible defaults exist
# -----------------------------------------------------------------------------

# OPENAI_ORGANIZATION_ID=org-...
# OPENAI_ORGANIZATION_ID is only needed if your key belongs to multiple orgs.

# Separate read-only role for NL-to-SQL execution (strongly recommended in prod).
# Falls back to DATABASE_URL if unset.
# DATABASE_QUERY_URL=postgresql://ai_readonly:xxx@host:5432/ai_dev_toolkit_production

# CORS — comma-separated list of origins allowed to hit /api/*
# CORS_ORIGINS=https://your-frontend.example,https://another.example

# Mailer
# MAILER_SENDER=noreply@your-domain.example

# Rails log level
# RAILS_LOG_LEVEL=info

# Puma
# WEB_CONCURRENCY=2
# RAILS_MAX_THREADS=5
# PORT=3000
