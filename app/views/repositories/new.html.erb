<% content_for :title, "Add repository" %>

<h1 class="text-2xl font-semibold mb-6">Add a repository</h1>

<%= form_with model: @repository, class: "max-w-xl space-y-4" do |f| %>
  <% if @repository.errors.any? %>
    <div class="p-3 bg-red-50 border border-red-300 text-red-900 rounded">
      <ul class="list-disc pl-5 text-sm">
        <% @repository.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :full_name, "GitHub repository (owner/name)", class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :full_name, placeholder: "rails/rails",
          class: "w-full px-3 py-2 border border-ink/20 rounded font-mono focus:outline-none focus:border-accent" %>
    <p class="text-xs text-ink/60 mt-1">Must be accessible with your configured GitHub token.</p>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Add & start indexing", class: "btn-primary" %>
    <%= link_to "Cancel", repositories_path, class: "btn" %>
  </div>
<% end %>
