<div class="max-w-sm mx-auto mt-8">
  <h1 class="text-2xl font-semibold mb-6">Create account</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <% if resource.errors.any? %>
      <div class="p-3 bg-red-50 border border-red-300 text-red-900 rounded text-sm">
        <ul class="list-disc pl-5">
          <% resource.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :name, autofocus: true, class: "w-full px-3 py-2 border border-ink/20 rounded" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email, autocomplete: "email",
            class: "w-full px-3 py-2 border border-ink/20 rounded" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-ink/20 rounded" %>
      <p class="text-xs text-ink/60 mt-1">At least <%= @minimum_password_length %> characters.</p>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-ink/20 rounded" %>
    </div>

    <%= f.submit "Create account", class: "btn-primary w-full justify-center" %>
  <% end %>

  <div class="mt-6 text-sm text-ink/60 text-center">
    <%= link_to "Already have an account? Sign in", new_session_path(resource_name), class: "hover:text-accent" %>
  </div>
</div>
